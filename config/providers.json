{
    "_comment": "Provider registry — add any OpenAI-compatible provider here without code changes.",
    "_usage": "Each provider entry defines how to discover itself from env vars. The provider_registry reads this file at startup.",
    "providers": {
        "mimo-token-plan": {
            "name": "MiMo Token Plan",
            "family": "mimo",
            "multi_key": true,
            "key_count": 4,
            "env_key_prefix": "MIMO_API_KEY_",
            "env_endpoint_prefix": "MIMO_ENDPOINT_",
            "env_model_prefix": "MIMO_MODEL_",
            "default_base_url": "https://token-plan-sgp.xiaomimimo.com/v1/chat/completions",
            "auth_style": "bearer",
            "default_model": "mimo-v2.5-pro",
            "available_models": ["mimo-v2.5-pro", "mimo-v2.5"],
            "protocol": "openai",
            "priority": 1,
            "cost": "paid"
        },
        "siliconflow": {
            "name": "SiliconFlow",
            "family": "openai",
            "multi_key": false,
            "env_key": "SILICONFLOW_API_KEY",
            "env_base_url": "SILICONFLOW_ENDPOINT",
            "default_base_url": "https://api.siliconflow.cn/v1/chat/completions",
            "auth_style": "bearer",
            "default_model": "moonshotai/Kimi-K2.7-Code",
            "available_models": ["moonshotai/Kimi-K2.7-Code", "Qwen/Qwen3-235B-A22B-Instruct"],
            "protocol": "openai",
            "priority": 10,
            "cost": "paid"
        },
        "deepseek": {
            "name": "DeepSeek",
            "family": "deepseek",
            "multi_key": false,
            "env_key": "DEEPSEEK_API_KEY",
            "env_base_url": "DEEPSEEK_ENDPOINT",
            "default_base_url": "https://api.deepseek.com/v1/chat/completions",
            "auth_style": "bearer",
            "default_model": "deepseek-v4-flash",
            "available_models": ["deepseek-v4-flash", "deepseek-v4-pro"],
            "protocol": "openai",
            "priority": 99,
            "is_fallback": true,
            "cost": "paid"
        }
    }
