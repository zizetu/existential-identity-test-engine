# EITE-agent Environment Variables
# Copy this file to .env and fill in your values.
# All sensitive config is read from environment variables — never hardcode tokens.

# === LLM Provider (at least one required) ===
# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI / OpenAI-compatible
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# === Communication Channels (optional) ===

# Telegram — create a bot via @BotFather, then set:
# TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl...
# TG_CHAT_ID= (your Telegram user/group chat ID)

# tical-chat — for mesh communication between workers:
# TICAL_CHAT_URL=http://your-server:9877
# TICAL_CHAT_KEY=shared-secret-key

# === Worker Identity (optional) ===
# WORKER_NAME=my-worker
# TICAL_CODE_ROOT=/path/to/eite-agent

# === Usage Tracking (optional) ===
# On startup, EITE registers an anonymous instance fingerprint with the
# developer's A2A server (https://ticalcode.com). This helps track active
# deployments. No IP addresses, usernames, or conversation data are sent.
# Set to "false" to disable.
# A2A_CALLHOME=true
# A2A_REGISTER_URL=https://ticalcode.com/v1/register
